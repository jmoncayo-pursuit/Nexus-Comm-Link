# Nexus Phone Connect Configuration

# Your password for the mobile interface
APP_PASSWORD=your-app-password
APP_SECRET=your-cookie-secret-key

# Your ngrok authtoken for remote access
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_VOICE_MODEL=models/gemini-2.5-flash-native-audio-preview-09-2025
GEMINI_SKIP_GREETING=false

# Google Cloud Project Configuration (for Vertex AI / Cloud Run)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Server Port
PORT=3131
NEXUS_API_PORT=9000
